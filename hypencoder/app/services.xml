<?xml version="1.0" encoding="utf-8" ?>
<services version="1.0" xmlns:deploy="vespa" xmlns:preprocess="properties" minimum-required-vespa-version="8.338.38">

  <!-- ===========================================================
       Hypencoder sample app

       Hypencoder (SIGIR '25, arxiv 2502.05364) replaces cosine similarity
       with a hypernetwork: the query encoder generates the weights of a
       small neural network at query time, and that q-net is applied per-doc
       to a stored embedding to produce the relevance score.

       This app demonstrates running Hypencoder entirely inside Vespa with
       no custom Java code:

         - hugging-face-embedder runs the passage encoder server-side
           at indexing time to produce 768-d CLS doc embeddings.

         - An onnx-model runs the query encoder (BERT + hyperhead) once
           per query, producing the q-net weights as named outputs.

         - The rank profile expresses the q-net forward pass as a chain
           of tensor expressions (matmul + bias + ReLU + LayerNorm +
           residual).

       Run model2onnx.py before deploying to produce models/passage_encoder.onnx,
       models/query_encoder.onnx, and models/tokenizer.json.
       =========================================================== -->
  <container id="default" version="1.0">

    <!-- Passage encoder: BERT-base from the Hypencoder.2_layer checkpoint,
         exported to ONNX. CLS pooling, no L2 normalization (matches
         TextEncoder.cls_pool in the original repo). -->
    <component id="passage_embedder" type="hugging-face-embedder">
      <transformer-model path="models/passage_encoder.onnx"/>
      <tokenizer-model path="models/tokenizer.json"/>
      <pooling-strategy>cls</pooling-strategy>
      <normalize>false</normalize>
    </component>

    <document-api/>
    <search/>
    <nodes count="1">
      <resources vcpu="4" memory="16Gb" disk="125Gb"/>
    </nodes>
  </container>

  <content id="content" version="1.0">
    <min-redundancy>1</min-redundancy>
    <documents>
      <document type="doc" mode="index"/>
    </documents>
    <nodes count="1"/>

    <!-- ==========================================================================================
         Optional: parallelize ranking across matched docs. Requires restart after deploy.
         ========================================================================================== -->
    <!--
    <engine>
      <proton>
        <tuning>
          <searchnode>
            <requestthreads>
              <persearch>4</persearch>
            </requestthreads>
          </searchnode>
        </tuning>
      </proton>
    </engine>
    -->
  </content>

</services>
