schema ad {

    document ad {

        field title type string {
            indexing: summary | index
        }

        # Center of the ad's service area. Used by geoLocation() / geoBoundingBox().
        field center type position {
            indexing: attribute | summary
        }

        # Same point as `center`, but exposed as plain scalar attributes so it
        # can be referenced from ranking expressions (the polygon_filter
        # rank-profile reads attribute(lat) and attribute(lon) directly).
        field lat type float {
            indexing: attribute | summary
        }
        field lon type float {
            indexing: attribute | summary
        }

        # Optional taxonomy/path filter, OR-combined with the service-area check below.
        # Equivalent to Elasticsearch "terms": { "location_path": [...] }.
        field location_path type array<string> {
            indexing: attribute | summary
            attribute: fast-search
            rank: filter
        }

        # ----- Service-area envelope, decomposed into 4 scalar attributes. -----
        # Vespa has no geo_shape / "envelope contains point" operator, but four
        # AND'ed range conditions are folded by the RangeQueryOptimizer into a
        # single MultiRangeItem lookup against the fast-search btree indexes,
        # which is the idiomatic Vespa equivalent.
        #
        # `float` (not `double`): at Berlin's latitude (52°), float's quantum
        # is ~0.7 m on lat and ~0.4 m on lon — three orders of magnitude finer
        # than the underlying service-area data (km-scale fuzz) and the query
        # point (GPS at ~5 m, usually rounded by the front-end). Halves the
        # attribute footprint and the fast-search btree; at 60M docs that's
        # ~960 MB saved across the four fields with no measurable precision
        # loss for envelope-contains-point queries.
        field sw_lat type float {
            indexing: attribute | summary
            attribute: fast-search
        }
        field ne_lat type float {
            indexing: attribute | summary
            attribute: fast-search
        }
        field sw_lon type float {
            indexing: attribute | summary
            attribute: fast-search
        }
        field ne_lon type float {
            indexing: attribute | summary
            attribute: fast-search
        }
    }

    fieldset default {
        fields: title
    }

    rank-profile default {
        first-phase {
            expression: nativeRank(title)
        }
    }

    # Used by PolygonSearcher to read each hit's lat/lon as a match-feature,
    # eliminating the summary fetch round-trip. Match-features ship back with
    # the initial content-node response, so the Searcher can apply the
    # ray-cast filter before any docsum is fetched — only the surviving hits
    # get their summary filled by the rendering layer.
    #
    # See https://vinted.engineering/2025/11/06/vespa-match-features/ for the
    # background — Vespa 8.596.7+ skips docsum fetching when only matchfeatures
    # are needed by the Searcher.
    rank-profile searcher_geo inherits default {
        function lat_mf() { 
            expression: attribute(lat) 
            }
        function lon_mf() { 
            expression: attribute(lon) 
            }
        match-features {
            lat_mf
            lon_mf
        }
    }

    # Combines title relevance with proximity to the query point, when one is given.
    rank-profile with_distance inherits default {
        first-phase {
            expression: nativeRank(title) + closeness(center)
        }
        summary-features {
            distance(center).km
        }
    }

    # Content-node polygon filter — alternative to the container-side
    # PolygonSearcher. Works for any simple polygon (convex or non-convex),
    # accepts arbitrary vertex winding, and drops outside-polygon docs on the
    # content nodes via `rank-score-drop-limit`, so filtering happens before
    # pagination — no container post-filter needed.
    #
    # Polygon is passed as four indexed-dim tensors (one per edge endpoint
    # coordinate). Indexed dims let Vespa use contiguous-array (SIMD-friendly)
    # kernels for the joins/reduces; the mapped-dim equivalent is ~7× slower
    # at scale due to hash-based per-cell access. See README §Polygon
    # benchmarks for the head-to-head numbers + profile breakdown.
    #
    # The polygon has up to 32 edges (the indexed bound). Unused trailing
    # cells default to 0.0, which the `crossings_per_edge` test treats as
    # non-crossing (one endpoint above, one below the query lat is false
    # when both are 0).
    #
    # Algorithm: ray-casting (PNPoly). For each edge, the point crosses
    # iff:
    #   v1 = (slat - lat) * (elat - lat) < 0   (edge straddles the ray's lat)
    #   v2 = numerator * denominator > 0       (intersection east of query lon)
    # where
    #   numerator   = (elon - slon) * (lat - slat) + (slon - lon) * (elat - slat)
    #   denominator = (elat - slat)
    # We use `numerator * denominator > 0` instead of `lon < numerator/denom`
    # because `sign(A/B) == sign(A*B)` for B != 0; that avoids divide-by-zero
    # on horizontal edges (where `v1` would be 0 anyway, so they're already
    # excluded from contributing).
    #
    # The point is inside iff the total number of crossings is odd
    # (`fmod(crossings, 2) > 0.5`).
    rank-profile polygon_filter inherits default {
        inputs {
            query(slat) tensor<float>(edge[32])
            query(slon) tensor<float>(edge[32])
            query(elat) tensor<float>(edge[32])
            query(elon) tensor<float>(edge[32])
        }
        function dlat() { 
            expression: query(elat) - query(slat) 
            }
        function v1() {
            # Strictly-negative when the edge straddles the query lat.
            expression: (query(slat) - attribute(lat)) * (query(elat) - attribute(lat))
        }
        function v2() {
            # Strictly-positive when the ray-edge intersection is east of the query lon.
            expression {
                ((query(elon) - query(slon)) * (attribute(lat) - query(slat))
                  + (query(slon) - attribute(lon)) * dlat)
                * dlat
            }
        }
        function crossings() {
            expression: reduce(join(v1, v2, f(a, b)(if(a < 0 && b > 0, 1, 0))), sum, edge)
        }
        function inside_polygon() {
            expression: if(fmod(crossings, 2) > 0.5, 1.0, 0.0)
        }
        first-phase {
            expression: if(inside_polygon > 0.5, nativeRank(title) + 1.0, -1.0)
            rank-score-drop-limit: 0.0
        }
        match-features {
            inside_polygon
        }
    }
}
